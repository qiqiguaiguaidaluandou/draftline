<Window x:Class="TZHJ.App.Views.ConfirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认"
        Width="400" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False"
        Background="White"
        FontFamily="Microsoft YaHei" FontSize="13">
  <StackPanel Margin="30,26,30,24">
    <TextBlock x:Name="TitleText" FontSize="17" FontWeight="SemiBold" Foreground="{StaticResource TextBrush}" />
    <TextBlock x:Name="MessageText" Foreground="{StaticResource TextSecondary}" FontSize="13"
               TextWrapping="Wrap" LineHeight="21" Margin="0,12,0,0" />
    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,26,0,0">
      <Button Content="取消" Width="88" Height="40" IsCancel="True" Margin="0,0,10,0" />
      <Button Content="确定" Width="88" Height="40" Style="{StaticResource BtnPrimary}"
              IsDefault="True" Click="OnConfirm" />
    </StackPanel>
  </StackPanel>
</Window>
