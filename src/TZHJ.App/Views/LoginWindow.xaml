<Window x:Class="TZHJ.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
        Title="图纸核价 / 挑图纸系统 — 登录"
        Height="440" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Microsoft YaHei" FontSize="13">
  <Grid Background="#16264A">
    <Border Background="White" CornerRadius="14" Width="344" VerticalAlignment="Center" Padding="30">
      <StackPanel>
        <Border Width="56" Height="56" CornerRadius="14" Background="{StaticResource AccentLight}" HorizontalAlignment="Center">
          <fi:SymbolIcon Symbol="DocumentTable" FontSize="30" Foreground="{StaticResource Accent}"
                         HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <TextBlock Text="图纸核价 / 挑图纸系统" FontSize="18" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,14,0,4" />
        <TextBlock Text="PC 客户端（WPF）· 本机固定操作员&#x0a;登录身份后续由 DHR 统一提供（SSO）"
                   Foreground="{StaticResource TextMuted}" FontSize="12" TextAlignment="Center" Margin="0,0,0,18" />

        <TextBlock Text="工号" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,5" />
        <TextBox Height="36" Text="{Binding EmployeeId, UpdateSourceTrigger=PropertyChanged}" />

        <TextBlock Text="密码" Foreground="{StaticResource TextSecondary}" Margin="0,12,0,5" />
        <PasswordBox x:Name="PasswordBox" Height="36" PasswordChanged="OnPasswordChanged" />

        <TextBlock Text="{Binding Error}" Foreground="#DC2626" FontSize="12" TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   Visibility="{Binding Error, Converter={StaticResource StringToVis}}" />

        <Button Content="登 录" Style="{StaticResource BtnPrimary}" Height="40" Margin="0,18,0,0"
                Command="{Binding LoginCommand}"
                IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBool}}" />
        <TextBlock Text="— 或 — 使用 DHR 单点登录（接入后启用）"
                   Foreground="{StaticResource TextMuted}" FontSize="11.5" HorizontalAlignment="Center" Margin="0,14,0,0" />
      </StackPanel>
    </Border>
  </Grid>
</Window>
