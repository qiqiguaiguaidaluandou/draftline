<UserControl x:Class="TZHJ.App.Views.ExceptionPoolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:fi="clr-namespace:FluentIcons.Wpf;assembly=FluentIcons.Wpf"
             xmlns:b="clr-namespace:TZHJ.App.Behaviors"
             FontFamily="Microsoft YaHei" FontSize="13">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource HeaderBg}" BorderBrush="{StaticResource Border1}" BorderThickness="0,0,0,1" Padding="24,16">
      <TextBlock Text="{Binding Title}" Style="{StaticResource PageTitle}" />
    </Border>

    <DockPanel Grid.Row="1" Margin="24,14,24,8" LastChildFill="False">
      <TextBlock DockPanel.Dock="Left" Text="{Binding PoolPath}" Foreground="{StaticResource TextMuted}"
                 FontFamily="Consolas" VerticalAlignment="Center" Margin="0,0,10,0" />
      <Button DockPanel.Dock="Left" Command="{Binding OpenFolderCommand}">
        <StackPanel Orientation="Horizontal">
          <fi:SymbolIcon Symbol="FolderOpen" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
          <TextBlock Text="打开文件夹" Margin="6,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
      <Button DockPanel.Dock="Right" Command="{Binding RefreshCommand}">
        <StackPanel Orientation="Horizontal">
          <fi:SymbolIcon Symbol="ArrowClockwise" FontSize="15" Foreground="{StaticResource TextSecondary}" VerticalAlignment="Center" />
          <TextBlock Text="刷新" Margin="6,0,0,0" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </DockPanel>

    <!-- 异常列表（圆角卡片框） -->
    <Border Grid.Row="2" Margin="24,0,24,20" CornerRadius="10" Background="White"
            BorderBrush="{StaticResource Border1}" BorderThickness="1" SnapsToDevicePixels="True">
      <DataGrid b:CornerClip.Radius="10" BorderThickness="0" ItemsSource="{Binding Items}" IsReadOnly="True">
        <DataGrid.Columns>
          <DataGridTextColumn Header="产品线组" Binding="{Binding GroupName}" Width="100"
                              ElementStyle="{StaticResource CellTextEllipsisToolTip}"
                              Visibility="{Binding DataContext.ShowGroupColumn, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BoolToVis}}" />
          <DataGridTextColumn Header="物料编码" Binding="{Binding MaterialCode}" Width="120" />
          <DataGridTextColumn Header="名称" Binding="{Binding DisplayName}" Width="*" />
          <DataGridTextColumn Header="来源批次" Binding="{Binding SourceBatch}" Width="240" />
          <DataGridTextColumn Header="异常原因" Binding="{Binding Reason}" Width="160"
                              ElementStyle="{StaticResource CellTextEllipsisToolTip}" />
          <DataGridTextColumn Header="挂起时间" Binding="{Binding SuspendedAt, StringFormat=MM-dd HH:mm}" Width="120" />
          <DataGridTemplateColumn Header="操作" Width="120">
            <DataGridTemplateColumn.CellTemplate>
              <DataTemplate>
                <Button Content="补处理" Style="{StaticResource BtnPrimary}" Padding="10,3"
                        Command="{Binding DataContext.ResolveCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        CommandParameter="{Binding}" />
              </DataTemplate>
            </DataGridTemplateColumn.CellTemplate>
          </DataGridTemplateColumn>
        </DataGrid.Columns>
      </DataGrid>
    </Border>
  </Grid>
</UserControl>
