<?xml version="1.0" encoding="utf-8"?>
<!--
  ClickOnce 发布配置（自动更新落地，对应路线图轨道 D4）。
  普通 `dotnet build` 不读本文件，只有显式选用本 Profile 发布时才生效，故不影响日常编译/CI。

  发布（在 Windows 上，需已安装 .NET 8 SDK）：
    dotnet publish src/Draftline.App/Draftline.App.csproj -p:PublishProfile=ClickOnceProfile
  或在 Visual Studio 右键 Draftline.App → 发布 → 选择本 Profile。

  上线前务必改两处占位（标了 TODO）：PublishUrl / InstallUrl 指向真实的发布目标
  （文件共享 \\server\share\Draftline 或 https 站点）。每次发布请递增 ApplicationVersion 末位
  （或 ApplicationRevision），客户端才能在下次启动时检测到新版本并更新。
-->
<Project>
  <PropertyGroup>
    <Configuration>Release</Configuration>
    <Platform>Any CPU</Platform>
    <TargetFramework>net8.0-windows</TargetFramework>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>

    <!-- 框架依赖发布（体积小，需目标机有 .NET 8 桌面运行时；Bootstrapper 可代装）。
         若想免预装、单机直跑，改为 true（自包含，体积大）。 -->
    <SelfContained>false</SelfContained>

    <PublishProtocol>ClickOnce</PublishProtocol>
    <PublishDir>bin\publish\</PublishDir>

    <!-- TODO: 改为真实发布目标。两者一般相同。 -->
    <PublishUrl>\\YOUR-SERVER\Draftline\</PublishUrl>
    <InstallUrl>\\YOUR-SERVER\Draftline\</InstallUrl>

    <!-- 安装到「开始菜单/添加删除程序」，而非仅在线运行；建桌面快捷方式。 -->
    <Install>true</Install>
    <InstallFrom>Web</InstallFrom>
    <CreateDesktopShortcut>true</CreateDesktopShortcut>

    <!-- 版本与更新：每次发布递增末位，客户端据此发现新版本。 -->
    <ApplicationVersion>1.0.0.0</ApplicationVersion>
    <ApplicationRevision>0</ApplicationRevision>

    <!-- 自动更新：启动前同步检查（UpdateMode=Foreground），保证「管理员发一次、
         所有客户端下次启动即最新」。UpdateRequired=false 时允许用户本次先用旧版。 -->
    <UpdateEnabled>true</UpdateEnabled>
    <UpdateMode>Foreground</UpdateMode>
    <UpdateRequired>false</UpdateRequired>

    <!-- 生成 ClickOnce 应用/部署清单 + 引导程序（按需装 .NET 桌面运行时）。 -->
    <GenerateManifests>true</GenerateManifests>
    <BootstrapperEnabled>true</BootstrapperEnabled>
    <SignManifests>false</SignManifests>

    <ProductName>图纸核价 / 挑图纸客户端</ProductName>
    <PublisherName>图纸核价系统</PublisherName>
    <OpenBrowserOnPublish>false</OpenBrowserOnPublish>
  </PropertyGroup>
</Project>
