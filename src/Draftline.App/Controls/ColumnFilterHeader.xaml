<UserControl x:Class="Draftline.App.Controls.ColumnFilterHeader"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root">
  <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
    <TextBlock Text="{Binding Title, ElementName=Root}" VerticalAlignment="Center" />

    <!-- ▼ 触发器：常规态灰色，处于筛选态时由代码后置改为主题色并加粗 -->
    <ToggleButton x:Name="FilterToggle" Margin="6,0,0,0" Padding="3,1" Cursor="Hand"
                  Background="Transparent" BorderThickness="0" Focusable="False"
                  Checked="OnDropDownOpened" ToolTip="筛选">
      <ToggleButton.Template>
        <ControlTemplate TargetType="ToggleButton">
          <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="4">
            <ContentPresenter />
          </Border>
        </ControlTemplate>
      </ToggleButton.Template>
      <TextBlock x:Name="Glyph" Text="&#x25BE;" FontSize="11"
                 Foreground="{StaticResource TextMuted}" VerticalAlignment="Center" />
    </ToggleButton>

    <!-- 筛选面板：搜索框 + (全选) + 值勾选列表 + 确定/清除 -->
    <Popup x:Name="FilterPopup" StaysOpen="False" AllowsTransparency="True"
           Placement="Bottom" PlacementTarget="{Binding ElementName=FilterToggle}"
           IsOpen="{Binding IsChecked, ElementName=FilterToggle, Mode=TwoWay}">
      <Border Background="{StaticResource PanelBg}" BorderBrush="{StaticResource Border2}"
              BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,4,10,10"
              MinWidth="220" MaxWidth="320">
        <Border.Effect>
          <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.18" Color="#334155" />
        </Border.Effect>
        <DockPanel>
          <TextBox x:Name="SearchBox" DockPanel.Dock="Top" Margin="0,0,0,8"
                   Padding="6,3" TextChanged="OnSearchChanged" />
          <CheckBox x:Name="SelectAll" DockPanel.Dock="Top" Content="(全选)" IsThreeState="True"
                    Margin="2,0,0,6" FontWeight="SemiBold" Click="OnSelectAllClick" />
          <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                      HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="清除筛选" MinWidth="72" Padding="10,4" Click="OnClear" />
            <Button Content="确定" MinWidth="64" Padding="10,4" Margin="8,0,0,0"
                    Style="{StaticResource BtnPrimary}" Click="OnApply" />
          </StackPanel>
          <ListBox x:Name="OptionList" MaxHeight="240" BorderThickness="0"
                   ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
              <Style TargetType="ListBoxItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="Focusable" Value="False" />
              </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding Display}" IsChecked="{Binding IsChecked, Mode=TwoWay}"
                          Margin="2,3" />
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>
    </Popup>
  </StackPanel>
</UserControl>
